{
  "name": "customer-tagging-tool",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/api",
    "dev:all": "concurrently --names \"api,web\" --prefix-colors \"blue,green\" \"npm run dev --workspace=apps/api\" \"cd ../Frontend && npm run dev\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  }
}
